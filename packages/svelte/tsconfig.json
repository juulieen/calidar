{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "verbatimModuleSyntax": false,
    "moduleResolution": "Bundler"
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"],
  "exclude": ["dist", "node_modules"]
}
