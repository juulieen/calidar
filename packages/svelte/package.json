{
  "name": "@calidar/svelte",
  "version": "0.0.1",
  "description": "Svelte 5 adapter for @calidar/core — headless calendar with Google/Outlook-style UX.",
  "license": "MIT",
  "author": "Julien Ollivier",
  "homepage": "https://github.com/juulieen/calidar/tree/main/packages/svelte#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juulieen/calidar.git",
    "directory": "packages/svelte"
  },
  "bugs": "https://github.com/juulieen/calidar/issues",
  "keywords": [
    "calendar",
    "svelte",
    "svelte5",
    "scheduler",
    "rrule",
    "recurrence",
    "timezone",
    "agenda",
    "events",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "svelte-package -i src -o dist && cp src/styles.css dist/styles.css",
    "dev": "svelte-package -w -i src -o dist",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "svelte-package -i src -o dist && cp src/styles.css dist/styles.css"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "dependencies": {
    "@calidar/core": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
